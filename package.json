{
  "name": "openthk",
  "version": "0.1.1",
  "description": "The first multi-LLM agent orchestration framework for building pipelines, orchestrators, and collaborative AI workflows",
  "type": "module",
  "bin": {
    "openthk": "./dist/cli/index.cjs"
  },
  "files": [
    "dist/",
    "examples/",
    "openthk.pipeline.yaml"
  ],
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "node scripts/build-cli.mjs",
    "build:binary": "bun build src/cli/index.ts --compile --outfile dist/openthk",
    "test": "bun test",
    "lint": "bunx @biomejs/biome check src/",
    "format": "bunx @biomejs/biome format --write src/",
    "typecheck": "bunx tsc --noEmit",
    "prepack": "bun run build",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "yaml": "^2.7.0",
    "better-sqlite3": "^11.8.0",
    "vectra": "^0.9.0",
    "chalk": "^5.4.0",
    "ora": "^8.1.0",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.1.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sicora-dev/Open-Thinking/"
  },
  "keywords": [
    "ai",
    "llm",
    "orchestrator",
    "pipeline",
    "multi-agent",
    "cli",
    "bun",
    "agents",
    "multi-llm"
  ]
}
